# OpenNVR — example environment file.
#
# Security posture
# ----------------
# OpenNVR follows the offline-first open security architecture described in
# Singh et al., "Eliminating Systemic IP Camera Vulnerabilities via
# Offline-First Open Security Architecture" (DOI 10.5281/zenodo.17261761).
# This file ships with NO usable secrets and NO usable default admin
# password by design — the server's startup validators will refuse to boot
# if any of the *_SECRET / *_KEY / *_API_KEY values are still placeholders.
#
# To bootstrap a new deployment:
#
#   1. Copy this file:           cp env.example .env
#   2. Generate strong secrets:  make secrets >> .env
#   3. Fill in DATABASE_URL.
#   4. Leave DEFAULT_ADMIN_PASSWORD unset — the admin account is created
#      in the "first-time-setup required" state. Visit /auth/first-time-setup
#      on first start to choose a password and enable MFA.
#
# See docs/SECURITY_ARCHITECTURE.md for the full mapping between OpenNVR's
# implementation and the paper's six systemic challenge categories.

# =============================================================================
# Database
# =============================================================================
# Note: the database name is `kavach` (project codename); change if you
# renamed the database in your own deployment.
DATABASE_URL=postgresql://user:password@localhost:5432/kavach

# =============================================================================
# JWT / Session
# =============================================================================
# Generate with: make secrets   (or: python -c "import secrets; print(secrets.token_urlsafe(48))")
# Startup validator rejects placeholder/weak/short values.
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# =============================================================================
# Application
# =============================================================================
# DEBUG MUST be False in any deployment beyond local development.
DEBUG=False
HOST=127.0.0.1
PORT=8000
APPLICATION_URL=http://localhost:8000
API_PREFIX=/api/v1

# =============================================================================
# MediaMTX — INGRESS (camera LAN / Docker bridge / VPN overlay)
# Zenodo 17261761 §4.2 Tier 2
# =============================================================================
# V-015 rejects any URL below that resolves outside the OpenNVR trust zone:
#
#   accepted:  loopback (127.0.0.1, ::1, localhost)
#              RFC1918  (10/8, 172.16/12, 192.168/16) — incl. Docker bridges
#              IPv6 ULA (fc00::/7), IPv4/IPv6 link-local
#   rejected:  public IPs, public FQDNs, the 0.0.0.0 wildcard bind
#
# There is NO escape-hatch flag. For browser-facing access over the uplink
# NIC, terminate TLS in a reverse proxy and use MEDIAMTX_EXTERNAL_* below
# (those URLs are intentionally outside this check).
MEDIAMTX_BASE_URL=http://127.0.0.1:8889
MEDIAMTX_STREAM_PREFIX=cam-
MEDIAMTX_PATH_MODE=id
MEDIAMTX_AUTO_PROVISION=True
MEDIAMTX_ADMIN_API=http://127.0.0.1:9997/v3
MEDIAMTX_HLS_URL=http://127.0.0.1:8888
MEDIAMTX_RTSP_URL=rtsp://127.0.0.1:8554
MEDIAMTX_PLAYBACK_URL=http://127.0.0.1:9996

# Recording segment length (seconds) the backend sends to MediaMTX per camera.
# Keep in sync with mediamtx.*.yml `recordSegmentDuration` (default 1h = 3600).
# Shorter values = more, smaller files (e.g. 300 = 5-min segments).
RECORDING_SEGMENT_SECONDS=3600

# V-019 (M1b): the MediaMTX YAML templates ship with rtspEncryption="yes"
# so the operator-facing RTSP server refuses plaintext clients. Some dev
# setups use mediamtx.local.yml which keeps rtspEncryption="no" because
# certs aren't provisioned. If you are intentionally running a permissive
# MediaMTX config, set this to True so the deviation is recorded in the
# boot audit log and surfaced via /api/v1/system/posture. This setting
# is *informational only* — OpenNVR cannot enforce MediaMTX's config.
MEDIAMTX_ALLOW_PLAINTEXT_OUTPUTS=False

# MediaMTX webhook secret. MUST match the X-MTX-Secret query parameter in
# mediamtx.yml (runOnInit, runOnRecordSegmentComplete).
# Generate with: make secrets   (or: openssl rand -hex 32)
MEDIAMTX_SECRET=

# =============================================================================
# Recording
# =============================================================================
# Use an absolute path. The path is resolved and locked-down at startup; any
# attempt to read/write outside this base (including via symlink) is rejected.
RECORDINGS_BASE_PATH=./recordings

# =============================================================================
# Default Admin User
# =============================================================================
# V-001: there is no shipped default password. The admin account is created
# in the "password_set=False" state and must be activated via the
# /auth/first-time-setup flow on first login. Leave DEFAULT_ADMIN_PASSWORD
# unset for the supported flow. If you must provision an initial password
# non-interactively (e.g. automated deployment), set it here — the account
# will still be marked first-time-setup-required so the operator is forced
# to change it on first login.
DEFAULT_ADMIN_USERNAME=admin
# DEFAULT_ADMIN_PASSWORD=
DEFAULT_ADMIN_EMAIL=admin@opennvr.local
DEFAULT_ADMIN_FIRST_NAME=System
DEFAULT_ADMIN_LAST_NAME=Administrator

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE_ENABLED=True
LOG_FILE_PATH=logs/server.log
LOG_FILE_MAX_SIZE_MB=50
LOG_FILE_BACKUP_COUNT=10
LOG_CONSOLE_ENABLED=True
LOG_JSON_FORMAT=True

# =============================================================================
# Credential Vault (cloud provider tokens, encrypted-at-rest camera passwords)
# =============================================================================
# Fernet key — generated with: make secrets
# (or: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
CREDENTIAL_ENCRYPTION_KEY=

# =============================================================================
# Internal service-to-service authentication (NVR <-> KAI-C)
# =============================================================================
# Generate with: make secrets
INTERNAL_API_KEY=

# KAI-C orchestrator. Local-only by default. Aligns with the paper's
# Customer Sovereignty / no-vendor-cloud principle (Zenodo 17261761 §4.1).
KAI_C_URL=http://localhost:8100
KAI_C_IP=127.0.0.1

# How server-side inference reaches adapters through KAI-C:
#   governed  Default. KAI-C's audited /api/v1/infer/{adapter} surface —
#             sovereignty checks, correlation IDs, audit log, NATS fan-out
#             (what the example apps and the metrics tap consume).
#   v1        Legacy /infer/local passthrough: same body, no governance,
#             no NATS. Escape hatch if the KAI-C registry misbehaves.
#   legacy    Pre-contract shared-volume file URIs (in-tree adapters only).
# OPENNVR_ADAPTER_CONTRACT=governed

# =============================================================================
# Offline-first policy (V-009 / V-022 — Zenodo 17261761 §3.4, §4.1)
# =============================================================================
# DEPLOYMENT_MODE controls whether routes that reach a non-local resource
# are enabled at all. Defaults to `offline` so a fresh install does not
# phone home for any reason.
#
#   offline       Default. Cloud-touching routes return 403. Operators can
#                 still read stored cloud metadata for cleanup. Best for
#                 air-gapped or on-prem deployments.
#   hybrid        Cloud features available, each outbound call audit-logged.
#   cloud         Everything allowed. For hosted/SaaS deployments that have
#                 explicitly accepted the sovereignty trade-off.
DEPLOYMENT_MODE=offline

# AI_SOVEREIGNTY controls where inference frames are allowed to go. The
# server-side value is read by core.config; the KAI-C-side value MUST be
# set to the same string (KAI-C runs in its own process and reads the env
# var directly).
#
#   local_only       Default. KAI-C refuses non-loopback adapter URLs and
#                    /infer/cloud (HuggingFace proxy) returns 403.
#   federated        Adapters may live off-host but raw frame data is
#                    refused; only anonymised parameter exchange is okay.
#   cloud_allowed    No boundary checks. Suitable only when the operator
#                    has explicitly accepted vendor-managed inference.
AI_SOVEREIGNTY=local_only
