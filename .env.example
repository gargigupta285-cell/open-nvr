# OpenNVR - Environment Configuration (single source of truth)
#
# You normally DON'T touch this file by hand. Just run the launcher:
#     ./start.sh      (Linux / macOS)
#     start.ps1       (Windows)
# On first run it copies this template to .env, generates strong secrets,
# and walks you through the handful of settings most people change. Every
# service in docker-compose.yml and the examples reads its config from the
# resulting .env - change a value there and re-run ./start.sh to apply it.
#
# ! The default secrets below are LOCAL-DEV placeholders. The installer
#   replaces them with random values automatically; never ship these as-is.

# ============================================================
# DATABASE
# ============================================================
POSTGRES_USER=opennvr_user
POSTGRES_PASSWORD=dev_postgres_pass_2024     # ! change for production
POSTGRES_DB=opennvr_db

# ============================================================
# SECURITY & AUTHENTICATION
# ============================================================
SECRET_KEY=dev_jwt_secret_key_f8a4b2c9e1d7a5f3b8c4e2a9d6f1b7c3   # ! change: openssl rand -hex 32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
CREDENTIAL_ENCRYPTION_KEY=CKLghtP4rWz8J9vN2xQ5mT7yU8kF6bD3eH1aG4cS0wE=   # ! change - never change after first run
INTERNAL_API_KEY=dev_internal_api_key_h9j2k5l8m3n6p1q4   # ! change: openssl rand -base64 32
MEDIAMTX_SECRET=dev_mediamtx_webhook_secret_x7y2z5a8b3c6d1e4   # ! change: openssl rand -hex 32

# ============================================================
# APPLICATION SETTINGS
# ============================================================
# DEBUG applies to host-native backend dev. The Docker core service reads
# OPENNVR_DEBUG instead (kept separate so a stray host DEBUG=release can't
# break the backend's boolean parsing). Leave both False for normal use.
DEBUG=False
OPENNVR_DEBUG=False
HOST=0.0.0.0
PORT=8000
APPLICATION_URL=http://localhost:8000
API_PREFIX=/api/v1

# ============================================================
# MEDIAMTX STREAMING SERVER
# ============================================================
# NOTE: the URLs below are used ONLY when you run the backend directly on
# the host (outside Docker) for development. In the Docker stack, the
# compose file overrides all of them with internal service-DNS names
# (http://mediamtx:8889, etc.), so you don't need to edit these for a
# normal `./start.sh` install. Leave them as-is unless you're doing
# host-native backend dev.
MEDIAMTX_BASE_URL=http://localhost:8889
MEDIAMTX_ADMIN_API=http://localhost:9997/v3
MEDIAMTX_API_URL=http://localhost:9997
MEDIAMTX_HLS_URL=http://localhost:8888
MEDIAMTX_RTSP_URL=rtsp://localhost:8554
MEDIAMTX_PLAYBACK_URL=http://localhost:9996
MEDIAMTX_STREAM_PREFIX=cam-
MEDIAMTX_PATH_MODE=id
MEDIAMTX_AUTO_PROVISION=True

# Recording segment length in seconds (3600 = 1-hour files).
RECORDING_SEGMENT_SECONDS=3600

# ============================================================
# DOCKER SERVICE NETWORKING
# ============================================================
BACKEND_HOST=opennvr_core
BACKEND_PORT=8000

# ============================================================
# RECORDING STORAGE
# ============================================================
# Path on the HOST where recordings are stored (created automatically if missing).
# Windows: C:/opennvr/recordings   Linux: /var/lib/opennvr/recordings
RECORDINGS_PATH=./recordings

# ============================================================
# AI INFERENCE (KAI-C + AI Adapters)
# ============================================================
# Controls which adapters KAI-C loads: local_only | cloud_allowed
# Keep local_only for a fully offline stack (the default, no external calls).
AI_SOVEREIGNTY=cloud_allowed

# Capture inference frames from MediaMTX's loopback path instead of opening a
# second RTSP session to the camera. True is best for almost everyone; set
# false only when MediaMTX and KAI-C run on different hosts.
INFERENCE_USE_MEDIAMTX_TAP=true

# Image tag for ghcr.io/open-nvr/core. Use "latest" or pin to a release (e.g. 0.1.2).
CORE_TAG=latest

# Image tag for all GHCR adapter images (whisper, piper, yolov8, blip, moondream).
ADAPTER_TAG=main

# Optional example selected by the interactive installer. Leave blank for core only.
OPENNVR_EXAMPLE=
OPENNVR_EXAMPLE_COMPOSE=
OPENNVR_EXAMPLE_PROFILE=

KAI_C_URL=http://127.0.0.1:8100
KAI_C_IP=127.0.0.1

# ============================================================
# DEFAULT ADMIN USER
# ============================================================
# Leave DEFAULT_ADMIN_PASSWORD blank - setup-token flow handles first login securely.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=
DEFAULT_ADMIN_EMAIL=admin@opennvr.local
DEFAULT_ADMIN_FIRST_NAME=System
DEFAULT_ADMIN_LAST_NAME=Administrator

# ============================================================
# NGINX TLS REVERSE PROXY
# ============================================================
# Force a specific LAN IP into the TLS cert SAN (start.sh auto-detects if unset).
#OPENNVR_HOST_IP=192.168.1.100

# Dual-NIC: set both to isolate camera traffic from operator traffic.
#CAMERA_NETWORK_INTERFACE=eth0
#MGMT_NETWORK_INTERFACE=eth1

# Manual nginx bind IP (auto-set by start.sh - only override if auto-detection is wrong).
#NGINX_BIND_HOST=0.0.0.0

# Docker bridge subnets - override only if 172.28/16 or 172.29/16 collide with your LAN.
#OPENNVR_DOCKER_SUBNET=172.28.0.0/16
#OPENNVR_PUBLIC_SUBNET=172.29.0.0/16

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO
LOG_FILE_ENABLED=True
LOG_FILE_PATH=logs/server.log
LOG_FILE_MAX_SIZE_MB=50
LOG_FILE_BACKUP_COUNT=10
LOG_CONSOLE_ENABLED=True
LOG_JSON_FORMAT=False

# ============================================================
# YOLOv8 MODEL (standard stack)
# ============================================================
# The standard stack copies pre-baked ONNX weights from this image on first
# boot. Override to ship your own fine-tuned model (build recipe in
# examples/yolov8-weights/README.md). After changing, wipe the cache:
# docker volume rm open-nvr_opennvr_yolov8_weights
#YOLOV8_WEIGHTS_IMAGE=ghcr.io/open-nvr/yolov8-weights:v8.3.0
#YOLOV8_WEIGHTS_URL=https://your-mirror.example.com/yolov8n.onnx
#YOLOV8_PT_URL=https://github.com/ultralytics/assets/releases/download/v8.3.0/yolov8s.pt

# ============================================================
# CAMERA-AGENT (voice assistant overlay)
# ============================================================
# Ollama model for the voice agent - must support tool calling.
# Options: qwen2.5:0.5b (low RAM) | qwen2.5:1.5b (default) | qwen2.5:3b (better quality)
OLLAMA_MODEL=qwen2.5:1.5b

# Whisper STT model size: tiny.en | base.en (default) | small.en (most accurate)
WHISPER_MODEL_SIZE=base.en

# Caption adapter for describe_camera: moondream (VQA + captions) | blip (captions only)
CAPTION_ADAPTER=moondream

# llama.cpp GGUF model repo (only if using llm_provider=llamacpp instead of Ollama).
#LLAMACPP_HF_REPO=Qwen/Qwen3-1.7B-GGUF:Q4_K_M

OLLAMA_KEEP_ALIVE=-1
