# ============================================================
# OpenNVR - Environment Configuration
# ============================================================
#
# QUICK START (Docker):
#   1. Copy this file:  cp .env.example .env   (Linux/macOS)
#                       copy .env.example .env  (Windows)
#   2. Generate real secrets (for production):
#        Linux/macOS:  ./scripts/generate-secrets.sh --write
#        Windows:      .\scripts\generate-secrets.ps1 -Write
#   3. Set RECORDINGS_PATH to your storage location (see below)
#   4. Run: ./start.sh   (Linux/macOS)  or  .\start.ps1  (Windows)
#
# SECURITY WARNING:
#   The default secrets below are for LOCAL DEVELOPMENT only.
#   Run the secrets generator before any internet-facing deployment!
#   Never commit your .env file — it is already in .gitignore.
#
# ============================================================

# ============================================================
# DATABASE
# ============================================================
POSTGRES_USER=opennvr_user
# ⚠ CHANGE FOR PRODUCTION: generate with ./scripts/generate-secrets.sh --write
POSTGRES_PASSWORD=dev_postgres_pass_2024
POSTGRES_DB=opennvr_db

# ============================================================
# SECURITY & AUTHENTICATION
# ============================================================

# JWT signing key — min 32 characters
# ⚠ CHANGE FOR PRODUCTION: openssl rand -hex 32
SECRET_KEY=dev_jwt_secret_key_f8a4b2c9e1d7a5f3b8c4e2a9d6f1b7c3

# JWT algorithm (leave as HS256)
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Fernet key for encrypting camera credentials in the database
# ⚠ CHANGE FOR PRODUCTION: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# CRITICAL: Never change this after first run — all stored camera passwords become unreadable!
CREDENTIAL_ENCRYPTION_KEY=CKLghtP4rWz8J9vN2xQ5mT7yU8kF6bD3eH1aG4cS0wE=

# Internal service-to-service API key (shared between backend and Kai-C)
# ⚠ CHANGE FOR PRODUCTION: openssl rand -base64 32
INTERNAL_API_KEY=dev_internal_api_key_h9j2k5l8m3n6p1q4

# MediaMTX webhook authentication secret
# ⚠ CHANGE FOR PRODUCTION: openssl rand -hex 32
MEDIAMTX_SECRET=dev_mediamtx_webhook_secret_x7y2z5a8b3c6d1e4

# ============================================================
# APPLICATION SETTINGS
# ============================================================
# Set to False in all production / internet-facing deployments
DEBUG=False
HOST=0.0.0.0
PORT=8000
APPLICATION_URL=http://localhost:8000
API_PREFIX=/api/v1

# ============================================================
# MEDIAMTX STREAMING SERVER
# ============================================================
# These are the URLs the backend uses to talk to MediaMTX.
# For Docker (bridge mode) these are overridden by docker-compose.yml.
# For local development they point to localhost.
MEDIAMTX_BASE_URL=http://localhost:8889
MEDIAMTX_ADMIN_API=http://localhost:9997/v3
MEDIAMTX_API_URL=http://localhost:9997
MEDIAMTX_HLS_URL=http://localhost:8888
MEDIAMTX_RTSP_URL=rtsp://localhost:8554
MEDIAMTX_PLAYBACK_URL=http://localhost:9996
MEDIAMTX_STREAM_PREFIX=cam-
MEDIAMTX_PATH_MODE=id
MEDIAMTX_AUTO_PROVISION=True

# Recording segment length (seconds) the backend sends to MediaMTX per camera.
# Keep in sync with mediamtx.docker.yml `recordSegmentDuration` (default 1h = 3600).
# Shorter values = more, smaller files (e.g. 300 = 5-min segments).
RECORDING_SEGMENT_SECONDS=3600

# ============================================================
# DOCKER SERVICE NETWORKING
# ============================================================
# Backend container name (used by MediaMTX to call webhook endpoints)
BACKEND_HOST=opennvr_core
BACKEND_PORT=8000

# ============================================================
# RECORDING STORAGE
# ============================================================
# Path on the HOST machine where recordings are stored.
# Docker mounts this path into both mediamtx and opennvr-core containers.
#
# Examples:
#   Linux:   RECORDINGS_PATH=/var/lib/opennvr/recordings
#   macOS:   RECORDINGS_PATH=/Users/Shared/opennvr-recordings
#   Windows: RECORDINGS_PATH=C:/opennvr/recordings
#
# The directory will be created automatically if it does not exist.
RECORDINGS_PATH=./recordings

# ============================================================
# AI INFERENCE (KAI-C + AI Adapters)
# ============================================================
# Set to true only if you have cloned the ai-adapter repo to ../ai-adapter
# and want the AI detection service to run.
# The installer sets this automatically.
AI_ENABLED=false

# Kai-C runs inside the opennvr-core container on port 8100.
# In Docker bridge mode 127.0.0.1 inside the container = itself (correct).
KAI_C_URL=http://127.0.0.1:8100
KAI_C_IP=127.0.0.1

# URL of the external AI Adapters service (opennvr_ai container).
# Only needed if you have cloned and enabled the ai-adapters service.
# Bridge mode (Windows/macOS):  ADAPTER_URL=http://opennvr_ai:9100
# Host mode   (Linux):           ADAPTER_URL=http://127.0.0.1:9100
# AI disabled (default):         leave commented out — docker-compose uses its own default
# ADAPTER_URL=

# ============================================================
# DEFAULT ADMIN USER
# ============================================================
# Created automatically on first startup if the user does not exist.
#
# ISSUE-26 / V-001 (Zenodo §3.1, ETSI EN 303 645 unique-credential):
# DEFAULT_ADMIN_PASSWORD is INTENTIONALLY LEFT BLANK. When this is
# empty the admin account is created with ``password_set=False`` and
# you complete the bootstrap via the one-time setup-token flow that
# ``./start.sh up`` surfaces in your terminal — that's the secure-by-
# default path.
#
# DO NOT uncomment / fill the password line below for a normal
# install. Only set DEFAULT_ADMIN_PASSWORD when you need a
# provisioned-credential bootstrap path (e.g. unattended deploy from
# a secrets manager). In that case the chosen password is honored as
# the initial admin password — make sure the value comes from your
# secrets store and is never committed.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=
DEFAULT_ADMIN_EMAIL=admin@opennvr.local
DEFAULT_ADMIN_FIRST_NAME=System
DEFAULT_ADMIN_LAST_NAME=Administrator

# ============================================================
# NGINX TLS REVERSE PROXY (ISSUE-6)
# ============================================================
# The Tier 0 compose ships an nginx service that terminates TLS on
# the host's public NIC and proxies to opennvr-core over the Docker
# internal bridge. This is what makes the UI reachable from a phone
# or laptop on your LAN at https://<server-ip>/ — without it,
# opennvr-core is bound to 127.0.0.1 only by design.
#
# OPENNVR_HOST_IP — usually leave commented out. `./start.sh up`
# auto-detects your LAN IP and bakes it into the TLS cert SAN
# automatically (ISSUE-6 v9). Set this only if:
#   (a) you want to force a specific IP / hostname into the cert
#       SAN (e.g. a stable hostname behind a router that DHCPs);
#   (b) auto-detection picked the wrong NIC and you want to
#       override it; or
#   (c) you're behind a reverse proxy / NAT and the cert needs to
#       match a public hostname rather than the host's LAN IP.
# If set, this value WINS over start.sh's auto-detection. Refresh
# the existing cert after changing this with: ./start.sh refresh-certs
#OPENNVR_HOST_IP=192.168.1.100

# ── NIC topology (ISSUE-6 v2) ──────────────────────────────
# OpenNVR runs in three shapes. start.sh auto-detects which one you
# have and configures nginx accordingly:
#
# 1. SINGLE-NIC (Pi on home WiFi, one routable interface).
#    Cameras and operators share the LAN. nginx binds to 0.0.0.0:443
#    automatically. No NIC-level isolation possible. Trust model:
#    "I trust my LAN" — fine for home setups.
#    → leave the two vars below COMMENTED OUT.
#
# 2. DUAL-NIC (recommended for businesses / security-sensitive
#    setups: cameras on one NIC, operators on another). nginx
#    must bind to the uplink NIC only so a compromised camera
#    cannot reach the UI. UNCOMMENT both vars below and set them
#    to your actual interface names (e.g. eth0, enp3s0). start.sh
#    refuses to boot if MGMT_NETWORK_INTERFACE has no IPv4.
#    VLAN-tagged sub-interfaces (eth0.10, eth0.20) work the same —
#    the kernel presents them as separate NICs.
#
# 3. MULTI-NIC, UNDECLARED. You have ≥2 NICs but haven't said which
#    is which. nginx falls back to 0.0.0.0:443 with a loud warning
#    so you know you're not getting NIC-level isolation. Either
#    declare the topology below or accept the warning consciously.
#
# Find your interface names with: `ip -4 -o addr show scope global`
# on Linux, `ifconfig` on macOS.
#CAMERA_NETWORK_INTERFACE=eth0
#MGMT_NETWORK_INTERFACE=eth1

# NGINX_BIND_HOST — optional manual override. start.sh's NIC
# auto-detection sets this for you; leave it unset unless you have
# a specific bind-IP you want to force.
#NGINX_BIND_HOST=0.0.0.0

# ── Docker bridge subnet (ISSUE-6 v7) ──────────────────────
# OpenNVR pins its Docker bridge to a deterministic RFC1918 subnet
# so the trust-zone claim is auditable and your home/office LAN
# doesn't accidentally collide with whatever Docker would have
# auto-picked. Default is 172.28.0.0/16 (well inside the V-015-
# accepted 172.16/12 range; uncommon in consumer LANs which
# default to 192.168.x).
#
# Override ONLY if your existing LAN already uses 172.28/16 —
# pick any other RFC1918 range (10/8, 172.16-31/x, 192.168/16)
# that doesn't collide with your LAN or any VPN you connect to.
#OPENNVR_DOCKER_SUBNET=172.28.0.0/16
# Production compose (docker-compose.yml) has a second bridge for
# AI-adapter egress; pinned to 172.29/16 by default.
#OPENNVR_PUBLIC_SUBNET=172.29.0.0/16

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO
LOG_FILE_ENABLED=True
LOG_FILE_PATH=logs/server.log
LOG_FILE_MAX_SIZE_MB=50
LOG_FILE_BACKUP_COUNT=10
LOG_CONSOLE_ENABLED=True
LOG_JSON_FORMAT=False

# ============================================================
# YOLOv8 MODEL (Tier 0)
# ============================================================
# The default YOLOv8n weights are pinned in docker-compose.tier0.yml.
# The init container downloads the upstream .pt checkpoint and exports
# to ONNX on first boot, then caches the result on the
# opennvr_yolov8_weights volume — subsequent boots skip everything.
#
# Uncomment to override.
#
# (1) Pre-built ONNX: a fine-tuned model or a private mirror that
#     already serves the exported file. When set, the init container
#     skips the .pt → ONNX export and curls this URL directly.
#YOLOV8_WEIGHTS_URL=https://your-mirror.example.com/yolov8n.onnx
#
# (2) Upstream .pt checkpoint: point at a different ultralytics
#     release tag or a different model size (yolov8{n,s,m,l,x}.pt).
#     The init container will download this and export to ONNX.
#YOLOV8_PT_URL=https://github.com/ultralytics/assets/releases/download/v8.3.0/yolov8s.pt
#
# Wipe the cached weights volume to force a re-export after changing
# either of the above:
#   docker compose -f docker-compose.tier0.yml down
#   docker volume rm open-nvr_opennvr_yolov8_weights
#   docker compose -f docker-compose.tier0.yml up -d

# ============================================================
# CAMERA-AGENT (voice assistant overlay)
# ============================================================
# LLM served by Ollama for the voice agent (camera-agent overlay). Must
# support tool calling. qwen2.5:1.5b is the fast CPU default (~1 GB, snappy
# tool calls); use qwen2.5:3b or llama3.2:3b for higher quality at more
# latency. Pulled by the ollama-model-pull compose service.
OLLAMA_MODEL=qwen2.5:1.5b

# Whisper STT model for the voice editions. tiny.en is the light, fast CPU
# default (~75 MB, lowest RAM/latency); bump to base.en for better accuracy on
# longer/noisier speech if you have the headroom. English-only avoids foreign-
# token hallucination on quiet audio.
WHISPER_MODEL_SIZE=tiny.en
